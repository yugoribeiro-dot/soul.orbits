# soul.orbits — environment variables
# Copy to .env and fill in real values. .env is gitignored.
# NEVER commit .env or paste these values into a chat.

# Meta Developer App credentials (from App Settings → Basic)
META_APP_ID=
META_APP_SECRET=

# Long-lived user access token (from token exchange, valid ~60 days)
META_ACCESS_TOKEN=

# Instagram Business Account ID (from /me/accounts → page → instagram_business_account)
IG_USER_ID=

# Public base URL for image hosting (set per-week or use raw.githubusercontent.com after pushing)
IMAGE_BASE_URL=
